{
    "manifest_version": 3,
    "name": "Polymarket APR",
    "version": "1.2.4",
    "description": "Adds a native-style APR (Annual Percentage Rate) calculator directly into the Polymarket trade widget.",
    "icons": {
        "128": "icon.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://polymarket.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_end"
        }
    ],
    "host_permissions": [
        "https://polymarket.com/*"
    ]
}
