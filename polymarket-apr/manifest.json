{
  "manifest_version": 3,
  "name": "Polymarket APR",
  "version": "1.2.6",
  "description": "A simple APR calculator directly in Polymarket",
  "icons": {
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://polymarket.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "host_permissions": ["https://polymarket.com/*"]
}
